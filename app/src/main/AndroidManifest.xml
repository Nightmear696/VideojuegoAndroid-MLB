<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VideojuegoAndroidMLB.Space">

        <!-- Pantalla de menú (launcher) - Primera pantalla -->
        <!-- Requisito: "La primera pantalla que aparezca ha de ser aquella
             en donde se introduzca el nombre y dos niveles de dificultad" -->
        <activity
            android:name=".MenuActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.VideojuegoAndroidMLB.Space">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Pantalla de juego -->
        <activity
            android:name=".GameActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.VideojuegoAndroidMLB.Space" />

        <!-- Pantalla de Game Over -->
        <activity
            android:name=".GameOverActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.VideojuegoAndroidMLB.Space" />

        <!-- MainActivity original (ya no es launcher) -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.VideojuegoAndroidMLB" />

    </application>

</manifest>